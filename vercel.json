{
  "installCommand": "echo \"Studio3 zero-install: skip npm install\"",
  "buildCommand": "node scripts/build.js",
  "outputDirectory": "dist",
  "functions": {
    "api/odoo.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/odoo", "destination": "/api/odoo.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
